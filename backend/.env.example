# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=3001
RUST_LOG=miransas_db=info,tower_http=info

# ── Internal PostgreSQL (SQLx / migrations) ───────────────────────────────────
# Format: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://sardor:changeme@localhost:5432/miransas_db
DATABASE_MAX_CONNECTIONS=10

# ── Authentication ────────────────────────────────────────────────────────────
# Password for POST /auth/login  (min 8 chars)
ADMIN_PASSWORD=replace-with-strong-admin-password

# HMAC-SHA256 secret for signing JWTs  (min 32 chars)
JWT_SECRET=replace-with-at-least-32-random-characters-here

# ── Secret storage ────────────────────────────────────────────────────────────
# AES-256-GCM key material (min 32 chars)
SECRET_KEY=replace-with-at-least-32-random-characters-here

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Public DB access (connection strings shown to users) ──────────────────────
MIRANSAS_PUBLIC_DB_HOST=panel.miransas.com
MIRANSAS_PUBLIC_DB_PORT=5432
MIRANSAS_PUBLIC_DB_NAME=miransas
